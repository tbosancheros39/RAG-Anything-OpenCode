# RAG-Anything MCP Server Configuration
# Copy this file to .env and fill in your values, or set environment variables directly.

# ---------------------------------------------------------------------------
# Required: OpenAI API Configuration
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-key-here

# Optional: Custom OpenAI-compatible endpoint (e.g., Azure, Ollama, local proxy)
# OPENAI_BASE_URL=http://localhost:11434/v1

# ---------------------------------------------------------------------------
# Model Selection
# ---------------------------------------------------------------------------
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
VISION_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# RAG-Anything Storage & Parsing
# ---------------------------------------------------------------------------
WORKING_DIR=./rag_storage
PARSER=docling
PARSE_METHOD=auto

# ---------------------------------------------------------------------------
# Performance Tuning
# ---------------------------------------------------------------------------
RAG_LLM_MAX_ASYNC=16
RAG_EMBED_MAX_ASYNC=16
RAG_LLM_MAX_TOKEN_SIZE=32768

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
